{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "palette": {
    "python_bg": "#cba6f7",
    "python": "#1e1e2e",

    "os_bg": "#cdd6f4",
    "os": "#1e1e2e",

    "path_bg": "#a6e3a1",
    "path": "#1e1e2e",

    "git_bg": "#fab387",
    "git": "#1e1e2e",

    "text": "#cdd6f4",

    "time": "#1e1e2e",
    "time_bg": "#cdd6f4"
  },
  "blocks": [
    {
      "type": "rprompt",
      "segments": [
        {
          "foreground": "p:time",
          "options": {
            "time_format": "15:04:05"
          },
          "style": "diamond",
          "leading_diamond": "\ue0b2",
          "background": "p:time_bg",
          "template": " <b>{{ .CurrentDate | date .Format }}</b> ",
          "type": "time"
        }
      ]
    },
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "foreground": "p:os",
          "options": {
            "alpine": "\uf300",
            "arch": "\uf303",
            "centos": "\uf304",
            "debian": "\uf306",
            "elementary": "\uf309",
            "fedora": "\uf30a",
            "gentoo": "\uf30d",
            "linux": "\ue712",
            "macos": "\uf179 ",
            "manjaro": "\uf312",
            "mint": "\uf30f",
            "opensuse": "\uf314",
            "raspbian": "\uf315",
            "ubuntu": "\uf31b ",
            "windows": "\ue62a "
          },
          "style": "diamond",
          "trailing_diamond": "\ue0b0",
          "background": "p:os_bg",
          "template": " <b>{{ if .WSL }}WSL at {{ end }}{{.Icon}}</b> ",
          "type": "os"
        },
        {
          "template": " <b>(\ue73c venv: {{ .Venv }})</b> ",
          "foreground": "p:python",
          "powerline_symbol": "\ue0b0",
          "type": "python",
          "style": "diamond",
          "trailing_diamond": "\ue0b0",
          "background": "p:python_bg"
        },
        {
          "options": {
            "folder_separator_icon": "/",
            "home_icon": "~",
            "max_depth": 2,
            "style": "agnoster_short"
          },
          "template": " <b>\ue5fe {{ .Path }}</b> ",
          "foreground": "p:path",
          "powerline_symbol": "\ue0b0",
          "type": "path",
          "style": "diamond",
          "trailing_diamond": "\ue0b0",
          "background": "p:path_bg"
        },
        {
          "options": {
            "branch_icon": "\ue725 ",
            "cherry_pick_icon": "\ue29b ",
            "commit_icon": "\uf417 ",
            "fetch_status": false,
            "fetch_upstream_icon": false,
            "merge_icon": "\ue727 ",
            "no_commits_icon": "\uf0c3 ",
            "rebase_icon": "\ue728 ",
            "revert_icon": "\uf0e2 ",
            "tag_icon": "\uf412 "
          },
          "template": " <b>{{ .UpstreamIcon }}{{ .HEAD }}{{if .BranchStatus }} {{ .BranchStatus }}{{ end }}{{ if .Working.Changed }} \uf044 {{ .Working.String }}{{ end }}{{ if and (.Working.Changed) (.Staging.Changed) }} |{{ end }}{{ if .Staging.Changed }} \uf046 {{ .Staging.String }}{{ end }}{{ if gt .StashCount 0 }} \uf0c7 {{ .StashCount }}{{ end }}</b> ",
          "foreground": "p:git",
          "powerline_symbol": "\ue0b0",
          "type": "git",
          "style": "diamond",
          "trailing_diamond": "\ue0b0",
          "background": "p:git_bg"
        },
        {
          "style": "plain",
          "foreground": "p:text",
          "template": "",
          "type": "text"
        }
      ]
    }
  ],
  "version": 8,
  "final_space": true
}
